// Firestore Security Rules — Safeguard Hub
// ─────────────────────────────────────────────────────────────
// Deploy these rules by pasting the whole file into the Firebase
// console: Firestore Database → Rules tab → paste → Publish.
//
// Phase 3 scope: users collection + invites collection.
//
// Key decisions:
//  • Regular users can read and write ONLY their own profile.
//  • Regular users cannot change their own `role` or `status`.
//  • Coordinators can read ALL user profiles and change role/status
//    on anyone. They're identified by `role == 'coordinator'` on
//    their own user document.
//  • The first Coordinator is bootstrapped manually by editing the
//    role field in the Firebase console on their user document.
//  • Coordinators can create/read invite records. Volunteers can't
//    see the invites collection at all.
//  • No deletes from the app — profiles and invites are kept for
//    audit trail. Admins can still delete in the console.
// ─────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────
    function isCoordinator() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinator';
    }

    function hasProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function unchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }

    function validUserCreate(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'email',
          'role',
          'status',
          'firstName',
          'lastName',
          'preferredName',
          'dob',
          'phone',
          'address',
          'emergencyContact',
          'ageGroups',
          'serviceTimes',
          'testimony',
          'attendingSince',
          'profileComplete',
          'createdAt'
        ])
        && request.resource.data.role == 'volunteer'
        && request.resource.data.status == 'in-process'
        && (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email == request.auth.token.email)
        && request.resource.data.createdAt == request.time;
    }

    function validUserSelfUpdate(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'firstName',
          'lastName',
          'preferredName',
          'dob',
          'phone',
          'address',
          'emergencyContact',
          'ageGroups',
          'serviceTimes',
          'testimony',
          'attendingSince',
          'profileComplete',
          'covenant',
          'policeCheck',
          'references',
          'training',
          'updatedAt'
        ])
        && unchanged('role')
        && unchanged('status')
        && unchanged('screening')
        && unchanged('renewalDueOn')
        && unchanged('activatedAt')
        && unchanged('activatedBy')
        && unchanged('updatedBy')
        && validSelfPoliceCheck()
        && validSelfReferences()
        && (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email == request.auth.token.email)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time);
    }

    function validSelfPoliceCheck() {
      let pc = request.resource.data.get('policeCheck', {});
      return pc is map
        && pc.keys().hasOnly(['submittedAt', 'clearedAt', 'expiresOn'])
        && request.resource.data.get('policeCheck', {}).get('clearedAt', null)
          == resource.data.get('policeCheck', {}).get('clearedAt', null)
        && request.resource.data.get('policeCheck', {}).get('expiresOn', null)
          == resource.data.get('policeCheck', {}).get('expiresOn', null);
    }

    function validSelfReferences() {
      let refs = request.resource.data.get('references', {'items': []}).get('items', []);
      let oldRefs = resource.data.get('references', {'items': []}).get('items', []);
      return refs is list
        && refs.size() <= 2
        && (
          refs.size() < 1
          || (
            refs[0] is map
            && refs[0].keys().hasOnly(['name', 'email', 'relationship', 'receivedAt'])
            && (
              refs[0].get('receivedAt', null) == null
              || (oldRefs.size() > 0 && refs[0].get('receivedAt', null) == oldRefs[0].get('receivedAt', null))
            )
          )
        )
        && (
          refs.size() < 2
          || (
            refs[1] is map
            && refs[1].keys().hasOnly(['name', 'email', 'relationship', 'receivedAt'])
            && (
              refs[1].get('receivedAt', null) == null
              || (oldRefs.size() > 1 && refs[1].get('receivedAt', null) == oldRefs[1].get('receivedAt', null))
            )
          )
        );
    }

    function validSubmissionFormPair() {
      return (request.resource.data.formCode == 'SG-FRM-001' && request.resource.data.tabName == 'People')
        || (request.resource.data.formCode == 'SG-FRM-002' && request.resource.data.tabName == 'References')
        || (request.resource.data.formCode == 'SG-FRM-004' && request.resource.data.tabName == 'Acknowledgements')
        || (request.resource.data.formCode == 'SG-FRM-005' && request.resource.data.tabName == 'Registrations')
        || (request.resource.data.formCode == 'SG-FRM-006' && request.resource.data.tabName == 'Incidents')
        || (request.resource.data.formCode == 'SG-FRM-007' && request.resource.data.tabName == 'Abuse Reports')
        || (request.resource.data.formCode == 'SG-FRM-012' && request.resource.data.tabName == 'Training Log');
    }

    function validSubmissionCreate() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && hasProfile()
        && request.resource.data.keys().hasOnly([
          'formCode',
          'formTitle',
          'tabName',
          'recordId',
          'rowData',
          'submittedBy',
          'submittedByEmail',
          'submittedAt',
          'status',
          'reviewedBy',
          'reviewedByEmail',
          'reviewedAt',
          'notes'
        ])
        && request.resource.data.formCode in [
          'SG-FRM-001',
          'SG-FRM-002',
          'SG-FRM-004',
          'SG-FRM-005',
          'SG-FRM-006',
          'SG-FRM-007',
          'SG-FRM-012'
        ]
        && request.resource.data.tabName in [
          'People',
          'References',
          'Acknowledgements',
          'Registrations',
          'Incidents',
          'Abuse Reports',
          'Training Log'
        ]
        && validSubmissionFormPair()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.submittedByEmail == request.auth.token.email
        && request.resource.data.submittedAt == request.time
        && request.resource.data.status == 'open'
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewedByEmail == null
        && request.resource.data.reviewedAt == null
        && request.resource.data.notes == ''
        && request.resource.data.rowData is list
        && request.resource.data.rowData.size() <= 100
        && request.resource.data.recordId is string
        && request.resource.data.recordId.size() <= 80;
    }

    function validSubmissionUpdate() {
      return isCoordinator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'notes',
          'reviewedAt',
          'reviewedBy',
          'reviewedByEmail',
          'updatedAt'
        ])
        && request.resource.data.status in ['open', 'reviewed', 'closed']
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 5000
        && request.resource.data.updatedAt == request.time
        && (
          request.resource.data.status == 'open'
          || (
            request.resource.data.reviewedAt == request.time
            && request.resource.data.reviewedBy == request.auth.uid
            && request.resource.data.reviewedByEmail == request.auth.token.email
          )
        );
    }

    // ─── Users collection ────────────────────────────────────
    match /users/{uid} {

      // Read: yourself OR any Coordinator.
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isCoordinator());

      // Create: only yourself, and only with a safe starting state.
      // Blocks anyone trying to sign up as a coordinator or skipping
      // the in-process status.
      allow create: if validUserCreate(uid);

      // Update:
      //   • As yourself, you can change any field EXCEPT role/status.
      //   • As a Coordinator, you can change anything on anyone.
      allow update: if validUserSelfUpdate(uid) || isCoordinator();

      // Delete: never from the app.
      allow delete: if false;
    }

    // ─── Invites collection ──────────────────────────────────
    // Coordinator-only. Invitees themselves don't need to read
    // these — they just click a link in an email and sign up.
    match /invites/{inviteId} {
      allow read, list, create, update: if isCoordinator();
      allow delete: if false;
    }

    // ─── Config collection ───────────────────────────────────
    // Site-wide config. Coordinator-only because config may contain
    // operational secrets or sensitive switches.
    match /config/{configId} {
      allow read: if isCoordinator();
      allow write: if false;
    }

    // ─── Submissions collection ──────────────────────────────
    // Every fillable form in the Hub writes a copy of its
    // submission here alongside the legacy Google Sheets write.
    // Coordinators review/triage them in the admin panel.
    //
    //  • Create: any signed-in + verified user with a profile.
    //    On create, `submittedBy` must be the caller's uid so
    //    nobody can impersonate someone else.
    //  • Read (single):  the submitter OR any Coordinator.
    //  • List (query):   Coordinators only.
    //  • Update:         Coordinators only (for status/notes).
    //  • Delete:         never from the app.
    match /submissions/{submissionId} {
      allow create: if validSubmissionCreate();

      allow get: if request.auth != null
                 && (resource.data.submittedBy == request.auth.uid || isCoordinator());

      allow list: if isCoordinator();

      allow update: if validSubmissionUpdate();

      allow delete: if false;
    }

    // ─── Everything else ─────────────────────────────────────
    // Deny by default. Future collections (incidents, submissions,
    // training records) will get their own match blocks when we
    // build those phases.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
