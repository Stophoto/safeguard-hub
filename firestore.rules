// Firestore Security Rules — Safeguard Hub
// ─────────────────────────────────────────────────────────────
// Deploy these rules by pasting the whole file into the Firebase
// console: Firestore Database → Rules tab → paste → Publish.
//
// Phase 3 scope: users collection + invites collection.
//
// Key decisions:
//  • Regular users can read and write ONLY their own profile.
//  • Regular users cannot change their own `role` or `status`.
//  • Coordinators can read ALL user profiles and manage status/
//    compliance on OTHER people — never their own, and they can
//    NOT change anyone's role. They're identified by
//    `role == 'coordinator'` on their own user document.
//  • Role changes (who is a Coordinator) are reserved for Safeguard
//    Lead Admins — the owner tier (Chris + Christin) — and never on
//    your own account.
//  • The first Coordinator is bootstrapped manually by editing the
//    role field in the Firebase console on their user document.
//  • Coordinators can create/read invite records. Volunteers can't
//    see the invites collection at all.
//  • No deletes from the app — profiles and invites are kept for
//    audit trail. Admins can still delete in the console.
// ─────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────
    function isCoordinator() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinator';
    }

    function isSafeguardLead() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.safeguard_lead == true;
    }

    function isSafeguardLeadAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.safeguard_lead_admin == true;
    }

    function hasTemporaryAbuseAccess(reportId) {
      return request.auth != null
        && hasProfile()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('temporaryAbuseAccess', {}) is map
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('temporaryAbuseAccess', {}).get('reportId', '') == reportId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('temporaryAbuseAccess', {}).get('expiresAt', request.time) > request.time;
    }

    function isBootstrapSafeguardLeadAdmin(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && request.auth.uid == '2JkW4k0Hx0QZ2kHFmVgoUrIk0Aw1';
    }

    function hasProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function unchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }

    function validUserCreate(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'email',
          'role',
          'status',
          'safeguard_lead',
          'safeguard_lead_admin',
          'mfaEnrolled',
          'firstName',
          'lastName',
          'preferredName',
          'dob',
          'phone',
          'address',
          'emergencyContact',
          'ageGroups',
          'serviceTimes',
          'programs',
          'childrenAreas',
          'testimony',
          'attendingSince',
          'profileComplete',
          'createdAt'
        ])
        && request.resource.data.role == 'volunteer'
        && request.resource.data.status == 'in-process'
        && request.resource.data.safeguard_lead == false
        && request.resource.data.safeguard_lead_admin == false
        && request.resource.data.mfaEnrolled == false
        && (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email == request.auth.token.email)
        && request.resource.data.createdAt == request.time;
    }

    function validUserSelfUpdate(uid) {
      // Compute the changed-keys set ONCE and reuse it in every sub-check
      // below. Recomputing diff() in each helper is what pushed a denied
      // self-write toward Firestore's per-evaluation expression limit.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.auth != null
        && request.auth.uid == uid
        && changed.hasOnly([
          'email',
          'firstName',
          'lastName',
          'preferredName',
          'dob',
          'phone',
          'address',
          'emergencyContact',
          'ageGroups',
          'serviceTimes',
          'programs',
          'childrenAreas',
          'testimony',
          'attendingSince',
          'profileComplete',
          'application',
          'covenant',
          'covenantHistory',
          'policeCheck',
          'references',
          'training',
          'updatedAt'
        ])
        && unchanged('role')
        && unchanged('status')
        && unchanged('safeguard_lead')
        && unchanged('safeguard_lead_admin')
        && unchanged('mfaEnrolled')
        && unchanged('screening')
        && unchanged('renewalDueOn')
        && unchanged('activatedAt')
        && unchanged('activatedBy')
        && unchanged('updatedBy')
        && validSelfApplication(changed)
        && validSelfCovenant(changed)
        && validSelfCovenantHistory(changed)
        && validSelfPoliceCheck(changed)
        && validSelfReferences(changed)
        && (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email == request.auth.token.email)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time);
    }

    function validCoordinatorUserUpdate(uid) {
      return isCoordinator()
        // Coordinators edit OTHER people's records only. Their own profile
        // must go through the volunteer self-update path, which pins all
        // compliance fields — so nobody can clear their own police check,
        // approve themselves, or activate themselves.
        && request.auth.uid != uid
        // Role changes are NOT here: promoting/demoting anyone is reserved
        // for Safeguard Lead Admins (see validRoleChangeUpdate below).
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'status',
          'firstName',
          'lastName',
          'preferredName',
          'dob',
          'phone',
          'address',
          'emergencyContact',
          'ageGroups',
          'serviceTimes',
          'programs',
          'childrenAreas',
          'testimony',
          'attendingSince',
          'profileComplete',
          'covenant',
          'covenantHistory',
          'policeCheck',
          'references',
          'training',
          'screening',
          'renewalDueOn',
          'activatedAt',
          'activatedBy',
          'updatedAt',
          'updatedBy'
        ])
        // If status is being changed, it must be one of the known values.
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
          || request.resource.data.status in ['in-process', 'active', 'paused', 'inactive', 'invited']
        );
    }

    // Role changes (who is a Coordinator, Leader, Volunteer) are reserved for
    // Safeguard Lead Admins — i.e. the owner tier (Chris + Christin). An
    // ordinary Coordinator can no longer promote anyone, and nobody can
    // change their OWN role.
    function validRoleChangeUpdate(uid) {
      return isSafeguardLeadAdmin()
        && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'role',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.role in ['volunteer', 'leader', 'coordinator']
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time)
        && (!request.resource.data.keys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid);
    }

    function validSafeguardAccessUpdate(uid) {
      // Self-exclusion: an admin cannot tick their own access boxes — a
      // second person must grant them. (The bootstrap branch below is the
      // documented one-time exception and should be deleted once both
      // Lead Admins are set up.)
      return ((isSafeguardLeadAdmin() && request.auth.uid != uid) || isBootstrapSafeguardLeadAdmin(uid))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'safeguard_lead',
          'safeguard_lead_admin',
          'mfaEnrolled',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.get('safeguard_lead', null) is bool
        && request.resource.data.get('safeguard_lead_admin', null) is bool
        && request.resource.data.get('mfaEnrolled', null) is bool
        && (
          request.resource.data.get('safeguard_lead', false) == false
          || request.resource.data.get('mfaEnrolled', false) == true
        )
        // Same 2FA requirement for the Lead ADMIN flag — the most powerful
        // role must never be easier to grant than the one below it.
        && (
          request.resource.data.get('safeguard_lead_admin', false) == false
          || request.resource.data.get('mfaEnrolled', false) == true
        )
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time)
        && (!request.resource.data.keys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid);
    }

    function validTemporaryAbuseAccessUpdate(uid) {
      let access = request.resource.data.get('temporaryAbuseAccess', null);
      // Self-exclusion: temporary report access must be granted BY one
      // admin TO someone else — an admin can't quietly grant themselves.
      return isSafeguardLeadAdmin()
        && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'temporaryAbuseAccess',
          'updatedAt',
          'updatedBy'
        ])
        && access is map
        && access.keys().hasOnly([
          'grantedBy',
          'grantedByEmail',
          'grantedAt',
          'expiresAt',
          'reason',
          'reportId'
        ])
        && access.grantedBy == request.auth.uid
        && access.grantedByEmail == request.auth.token.email
        && access.grantedAt == request.time
        && access.expiresAt is timestamp
        && access.expiresAt > request.time
        && access.reason is string
        && access.reason.size() > 0
        && access.reason.size() <= 1000
        && access.reportId is string
        && access.reportId.size() > 0
        && access.reportId.size() <= 120
        && request.resource.data.updatedAt == request.time
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function validSelfApplication(changed) {
      let app = request.resource.data.get('application', {});
      return !changed.hasAny(['application'])
        || (
          app is map
          && app.keys().hasOnly(['submittedAt', 'recordId', 'isYouth'])
          && app.keys().hasAll(['submittedAt', 'recordId', 'isYouth'])
          && app.submittedAt is string
          && app.submittedAt.size() > 0
          && app.submittedAt.size() <= 40
          && app.recordId is string
          && app.recordId.size() > 0
          && app.recordId.size() <= 80
          && app.isYouth is bool
        );
    }

    function validSelfCovenant(changed) {
      let cov = request.resource.data.get('covenant', {});
      return !changed.hasAny(['covenant'])
        || (
          cov is map
          && cov.keys().hasOnly(['signed', 'signedAt', 'signatureName', 'expiresAt'])
          && cov.keys().hasAll(['signed', 'signedAt', 'signatureName', 'expiresAt'])
          && cov.signed == true
          && cov.signedAt is string
          && cov.signedAt.size() > 0
          && cov.signedAt.size() <= 40
          && cov.signatureName is string
          && cov.signatureName.size() > 0
          && cov.signatureName.size() <= 150
          && cov.expiresAt is string
          && cov.expiresAt.size() > 0
          && cov.expiresAt.size() <= 40
        );
    }

    function validCovenantArchive(archive) {
      return archive is map
        && archive.keys().hasOnly(['signedAt', 'signatureName', 'expiresAt'])
        && archive.get('signedAt', null) == resource.data.get('covenant', {}).get('signedAt', null)
        && archive.get('signatureName', '') == resource.data.get('covenant', {}).get('signatureName', '')
        && archive.get('expiresAt', null) == resource.data.get('covenant', {}).get('expiresAt', null);
    }

    function validSelfCovenantHistory(changed) {
      let history = request.resource.data.get('covenantHistory', []);
      let oldHistory = resource.data.get('covenantHistory', []);
      return !changed.hasAny(['covenantHistory'])
        || (
          history is list
          && oldHistory is list
          && oldHistory.size() < 50
          && history.size() == oldHistory.size() + 1
          && history.hasAll(oldHistory)
          && changed.hasAny(['covenant'])
          && resource.data.get('covenant', {}).get('signed', false) == true
          && validCovenantArchive(history[history.size() - 1])
        );
    }

    function validSelfPoliceCheck(changed) {
      let pc = request.resource.data.get('policeCheck', {});
      // Only validate when the volunteer is actually touching policeCheck —
      // otherwise an unrelated self-edit (phone, covenant, …) would be
      // rejected just because a coordinator-written key (followUpAt) exists.
      return !changed.hasAny(['policeCheck'])
        || (
          pc is map
          && pc.keys().hasOnly(['submittedAt', 'clearedAt', 'expiresOn', 'followUpAt'])
          && (
            pc.get('submittedAt', null) == null
            || (pc.submittedAt is string && pc.submittedAt.size() > 0 && pc.submittedAt.size() <= 40)
          )
          // Coordinator-owned fields are pinned: the volunteer can never
          // set or clear their own clearance, expiry, or follow-up flag.
          && pc.get('clearedAt', null) == resource.data.get('policeCheck', {}).get('clearedAt', null)
          && pc.get('expiresOn', null) == resource.data.get('policeCheck', {}).get('expiresOn', null)
          && pc.get('followUpAt', null) == resource.data.get('policeCheck', {}).get('followUpAt', null)
        );
    }

    // One reference entry: known keys only, sane sizes.
    function validRefItem(item) {
      return item is map
        && item.keys().hasOnly(['name', 'email', 'relationship', 'receivedAt'])
        && item.get('name', '') is string
        && item.get('name', '').size() <= 150
        && item.get('email', '') is string
        && item.get('email', '').size() <= 200
        && item.get('relationship', '') is string
        && item.get('relationship', '').size() <= 150;
    }

    // Once a coordinator has marked reference i as received, the volunteer
    // can no longer change WHO vouched (name/email/relationship), un-receive
    // it, or remove it. Before that, they may edit freely.
    function refPreservedIfReceived(newRefs, oldRefs, i) {
      return oldRefs.size() <= i
        || oldRefs[i].get('receivedAt', null) == null
        || (
          newRefs.size() > i
          && newRefs[i].get('name', '') == oldRefs[i].get('name', '')
          && newRefs[i].get('email', '') == oldRefs[i].get('email', '')
          && newRefs[i].get('relationship', '') == oldRefs[i].get('relationship', '')
          && newRefs[i].get('receivedAt', null) == oldRefs[i].get('receivedAt', null)
        );
    }

    function validSelfReferences(changed) {
      let refsMap = request.resource.data.get('references', {'items': []});
      let refs = refsMap.get('items', []);
      let oldRefs = resource.data.get('references', {'items': []}).get('items', []);
      return !changed.hasAny(['references'])
        || (
          refsMap is map
          && refsMap.keys().hasOnly(['items'])
          && refs is list
          && refs.size() <= 2
          && (
            refs.size() < 1
            || (
              validRefItem(refs[0])
              && (
                refs[0].get('receivedAt', null) == null
                || (oldRefs.size() > 0 && refs[0].get('receivedAt', null) == oldRefs[0].get('receivedAt', null))
              )
            )
          )
          && (
            refs.size() < 2
            || (
              validRefItem(refs[1])
              && (
                refs[1].get('receivedAt', null) == null
                || (oldRefs.size() > 1 && refs[1].get('receivedAt', null) == oldRefs[1].get('receivedAt', null))
              )
            )
          )
          && refPreservedIfReceived(refs, oldRefs, 0)
          && refPreservedIfReceived(refs, oldRefs, 1)
        );
    }

    function validSubmissionFormPair() {
      return (request.resource.data.formCode == 'SG-FRM-001' && request.resource.data.tabName == 'People')
        || (request.resource.data.formCode == 'SG-FRM-002' && request.resource.data.tabName == 'References')
        || (request.resource.data.formCode == 'SG-FRM-004' && request.resource.data.tabName == 'Acknowledgements')
        || (request.resource.data.formCode == 'SG-FRM-005' && request.resource.data.tabName == 'Registrations')
        || (request.resource.data.formCode == 'SG-FRM-006' && request.resource.data.tabName == 'Incidents')
        || (request.resource.data.formCode == 'SG-FRM-012' && request.resource.data.tabName == 'Training Log');
    }

    function validSubmissionCreate() {
      return request.auth != null
        && hasProfile()
        && request.resource.data.keys().hasOnly([
          'formCode',
          'formTitle',
          'tabName',
          'recordId',
          'rowData',
          'submittedBy',
          'submittedByEmail',
          'submittedAt',
          'status',
          'reviewedBy',
          'reviewedByEmail',
          'reviewedAt',
          'notes'
        ])
        && request.resource.data.formCode in [
          'SG-FRM-001',
          'SG-FRM-002',
          'SG-FRM-004',
          'SG-FRM-005',
          'SG-FRM-006',
          'SG-FRM-012'
        ]
        && request.resource.data.tabName in [
          'People',
          'References',
          'Acknowledgements',
          'Registrations',
          'Incidents',
          'Training Log'
        ]
        && validSubmissionFormPair()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.submittedByEmail == request.auth.token.email
        && request.resource.data.submittedAt == request.time
        && request.resource.data.status == 'open'
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewedByEmail == null
        && request.resource.data.reviewedAt == null
        && request.resource.data.notes == ''
        && request.resource.data.rowData is list
        && request.resource.data.rowData.size() <= 100
        && request.resource.data.recordId is string
        && request.resource.data.recordId.size() <= 80;
    }

    function validSubmissionUpdate() {
      return isCoordinator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'notes',
          'reviewedAt',
          'reviewedBy',
          'reviewedByEmail',
          'updatedAt'
        ])
        && request.resource.data.status in ['open', 'reviewed', 'closed']
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 5000
        && request.resource.data.updatedAt == request.time
        && (
          request.resource.data.status == 'open'
          || (
            request.resource.data.reviewedAt == request.time
            && request.resource.data.reviewedBy == request.auth.uid
            && request.resource.data.reviewedByEmail == request.auth.token.email
          )
        );
    }

    function validAbuseReportCreate() {
      return request.auth != null
        && hasProfile()
        && request.resource.data.keys().hasOnly([
          'schemaVersion',
          'formCode',
          'formTitle',
          'tabName',
          'recordId',
          'rowData',
          'submittedBy',
          'submittedByEmail',
          'submittedAt',
          'status',
          'assignedLeadUid',
          'allowedReaders',
          'reviewedBy',
          'reviewedByEmail',
          'reviewedAt',
          'closedBy',
          'closedAt',
          'closureReason',
          'notes',
          'legalHold',
          'retentionUntil',
          'createdVia'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.formCode == 'SG-FRM-007'
        && request.resource.data.tabName == 'Abuse Reports'
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.submittedByEmail == request.auth.token.email
        && request.resource.data.submittedAt == request.time
        && request.resource.data.status == 'open'
        && request.resource.data.assignedLeadUid == null
        && request.resource.data.allowedReaders is list
        && request.resource.data.allowedReaders.size() == 0
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewedByEmail == null
        && request.resource.data.reviewedAt == null
        && request.resource.data.closedBy == null
        && request.resource.data.closedAt == null
        && request.resource.data.closureReason == ''
        && request.resource.data.notes == ''
        && request.resource.data.legalHold == true
        && request.resource.data.retentionUntil == null
        && request.resource.data.createdVia == 'direct-client-phase-a'
        && request.resource.data.rowData is list
        && request.resource.data.rowData.size() <= 100
        && request.resource.data.recordId is string
        && request.resource.data.recordId.size() <= 80;
    }

    function validAbuseReportUpdate() {
      return isSafeguardLead()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'assignedLeadUid',
          'reviewedBy',
          'reviewedByEmail',
          'reviewedAt',
          'closedBy',
          'closedAt',
          'closureReason',
          'notes',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.status in ['open', 'reviewed', 'closed']
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 5000
        && request.resource.data.updatedAt == request.time
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.legalHold == resource.data.legalHold
        && request.resource.data.retentionUntil == resource.data.retentionUntil
        && (
          request.resource.data.status != 'closed'
          || (
            request.resource.data.closureReason is string
            && request.resource.data.closureReason.size() > 0
            && request.resource.data.closureReason.size() <= 5000
            && request.resource.data.closedAt == request.time
            && request.resource.data.closedBy == request.auth.uid
          )
        );
    }

    // ─── Users collection ────────────────────────────────────
    match /users/{uid} {

      // Read: yourself OR any Coordinator.
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isCoordinator());

      // Create: only yourself, and only with a safe starting state.
      // Blocks anyone trying to sign up as a coordinator or skipping
      // the in-process status.
      allow create: if validUserCreate(uid);

      // Update:
      //   • As yourself, you can change only volunteer-owned fields.
      //   • Coordinators can manage ordinary profile/compliance fields
      //     on OTHER people (never their own compliance).
      //   • Only Safeguard Lead Admins (the owner tier) can change roles.
      //   • Safeguard Lead Admins can manage safeguard_lead flags — on
      //     others, never themselves.
      // Split by WHOSE record this is. A write is either editing your own
      // profile or someone else's — never both — so we only evaluate the
      // relevant group. This keeps any single evaluation well under
      // Firestore's expression-complexity limit (the heavy self-update
      // validator is never run on a coordinator's write, and vice-versa).
      // Editing your OWN record: ordinary self-service, OR the one-time
      // bootstrap self-grant (validSafeguardAccessUpdate's bootstrap branch).
      allow update: if (request.auth != null && request.auth.uid == uid)
                    ? ( validUserSelfUpdate(uid)
                        || validSafeguardAccessUpdate(uid) )
                    : ( validCoordinatorUserUpdate(uid)
                        || validRoleChangeUpdate(uid)
                        || validSafeguardAccessUpdate(uid)
                        || validTemporaryAbuseAccessUpdate(uid) );

      // Delete: coordinators may remove ONLY a duplicate / mistaken
      // account — one with NO safeguarding history (not active, no cleared
      // police check, no signed covenant). Real volunteers can never be
      // deleted; pause them instead.
      allow delete: if isCoordinator()
                    && resource.data.get('status', '') != 'active'
                    && resource.data.get('policeCheck', {}).get('clearedAt', null) == null
                    && resource.data.get('covenant', {}).get('signed', false) != true;
    }

    // ─── Invites collection ──────────────────────────────────
    // Coordinator-only. Invitees themselves don't need to read
    // these — they just click a link in an email and sign up.
    match /invites/{inviteId} {
      allow read, list, create, update: if isCoordinator();
      allow delete: if false;
    }

    // ─── Config collection ───────────────────────────────────
    // Site-wide config. Coordinator-only because config may contain
    // operational secrets or sensitive switches.
    match /config/{configId} {
      allow read: if isCoordinator();
      allow write: if false;
    }

    // ─── Submissions collection ──────────────────────────────
    // Every fillable form in the Hub writes a copy of its
    // submission here alongside the legacy Google Sheets write.
    // Coordinators review/triage them in the admin panel.
    //
    //  • Create: any signed-in + verified user with a profile.
    //    On create, `submittedBy` must be the caller's uid so
    //    nobody can impersonate someone else.
    //  • Read (single):  the submitter OR any Coordinator.
    //  • List (query):   Coordinators only.
    //  • Update:         Coordinators only (for status/notes).
    //  • Delete:         never from the app.
    match /submissions/{submissionId} {
      allow create: if validSubmissionCreate();

      allow get: if request.auth != null
                 && (resource.data.submittedBy == request.auth.uid || isCoordinator());

      allow list: if isCoordinator();

      allow update: if validSubmissionUpdate();

      // Delete: coordinators may clean up ordinary submissions when removing
      // a duplicate account — never incident (SG-FRM-006) or abuse reports.
      allow delete: if isCoordinator()
                    && resource.data.get('formCode', '') != 'SG-FRM-006'
                    && resource.data.get('formCode', '') != 'SG-FRM-007';
    }

    // ─── Abuse reports collection ───────────────────────────
    // Phase A: no Cloud Functions. Verified users can create a
    // locked-down SG-FRM-007 document directly. Only Safeguard
    // Leads can read/list/update report documents.
    match /abuseReports/{reportId} {
      allow create: if validAbuseReportCreate();
      allow get: if isSafeguardLead() || hasTemporaryAbuseAccess(reportId);
      allow list: if isSafeguardLead();
      allow update: if validAbuseReportUpdate();
      allow delete: if false;
    }

    match /leadNotifications/{notificationId} {
      allow create: if isSafeguardLeadAdmin()
                    && request.resource.data.keys().hasOnly([
                      'type',
                      'targetUid',
                      'reportId',
                      'reason',
                      'grantedBy',
                      'grantedByEmail',
                      'grantedAt',
                      'expiresAt'
                    ])
                    && request.resource.data.type == 'temporaryAbuseAccess'
                    && request.resource.data.grantedBy == request.auth.uid
                    && request.resource.data.grantedByEmail == request.auth.token.email
                    && request.resource.data.grantedAt == request.time;
      allow get, list: if isSafeguardLead();
      allow update, delete: if false;
    }

    // ─── Admin rhythm (coordinator's recurring-task memory) ──
    // One doc (/adminRhythm/current) holds "last done" stamps for the
    // recurring coordinator tasks shown on the Admin Dashboard.
    match /adminRhythm/{docId} {
      allow read, write: if isCoordinator();
    }

    // ─── Everything else ─────────────────────────────────────
    // Deny by default. Future collections (incidents, submissions,
    // training records) will get their own match blocks when we
    // build those phases.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
